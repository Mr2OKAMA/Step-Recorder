{
  "manifest_version": 3,
  "name": "Tango Light Recorder",
  "version": "1.1",
  "description": "Tango風の操作手順書自動作成ツール",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}